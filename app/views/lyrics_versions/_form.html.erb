<%= form_with(model: lyrics_version) do |form| %>
  <% if lyrics_version.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(lyrics_version.errors.count, "error") %> prohibited this lyrics_version from being saved:</h2>

      <ul>
        <% lyrics_version.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :song_id %>
  <%= form.hidden_field :previous_version_id %>
  <%= form.hidden_field :is_proposal %>

  <div>
    <%= form.label :lyrics, style: "display: block" %>
    <%= form.textarea :lyrics %>
  </div>

  <p>
    <%= form.label :description, "Changes description", style: "display: block" %>
    <%= form.text_field :description %>
  </p>

  <p>
    <%= form.submit %>
  </p>
<% end %>
