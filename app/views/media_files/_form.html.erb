<%= form_with(model: media_file) do |form| %>
  <% if media_file.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(media_file.errors.count, "error") %> prohibited this media_file from being saved:</h2>

      <ul>
        <% media_file.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :song_id, style: "display: block" %>
    <%= form.text_field :song_id %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :file, style: "display: block" %>
    <%= form.file_field :file %>
    <%= form.hidden_field :file_cache %>
  </div>


  <div>
    <%= form.submit %>
  </div>
<% end %>
